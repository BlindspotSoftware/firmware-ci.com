<div class="wrapper contact">
  <div class="contact__intro flow">
    <h1 class="text-4xl weight-ultrabold">Get in touch</h1>
    <p class="text-lg text-gray-2">
      Questions about FirmwareCI, want a demo, or ready to get your hardware
      tested? Drop us a line — we read every message.
    </p>
  </div>

  <div class="card contact__card">
    <span class="contact__label">Email us at</span>
    <a class="contact__email" href="mailto:hello@blindspot.software">hello@<wbr>blindspot.software</a>
    <div class="cluster contact__actions" style="--cluster-gap: var(--space-2xs)">
      <a class="button button--glow" href="mailto:hello@blindspot.software">
        Open in mail app <span class="button__arrow" aria-hidden="true">→</span>
      </a>
      <button type="button" class="button" data-copy="hello@blindspot.software">Copy address</button>
    </div>
  </div>

  <p class="contact__meta text-gray-2">
    Prefer to read first? Head to the
    <a href="https://docs.firmware-ci.com" target="_blank" rel="noopener noreferrer">documentation</a>.
  </p>
</div>
