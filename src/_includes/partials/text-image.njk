<section class="text-image | section {{ "bg-white" if section.bg === 'white' }}" {{ "id=" + section.id  | safe if section.id }}>
  <div class="wrapper | text-image__content {{ 'text-image__content--reverse' if reverse }}">
    <div class="text-image__copy">
      <h1 class="text-xl lg:text-2xl weight-ultrabold">{{ section.headline }}</h1>
      <p class="lg:text-md text-gray-2">{{ section.text }}</p>

      {% if section.painpoint %}
        <p class="text-image__painpoint">{{ section.painpoint }}</p>
      {% endif %}

      {%- if section.links -%}
        <div class="cluster pt-xs" style="--cluster-gap: var(--space-2xs)">
          {%- for link in section.links -%}
            <a 
              href="{{ link.url }}"
              class="button {{ 'button--primary' if loop.index0 === 0 else 'button--secondary' }}"
              {{ "rel='noopener noreferrer' target='_blank'" | safe if link.url.startsWith('http')  }}
            >
              {{ link.label }}
            </a>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>

    {% if section.graphic %}
      <div class="text-image__graphic text-image__graphic--{{ section.graphic }}" aria-hidden="true"></div>
    {% elif section.darkImage %}
      <img
        class="themed-media themed-media--light"
        eleventy:widths="600, 900, 1200, 1600"
        eleventy:formats="avif,webp"
        src="/assets/images/{{ section.image }}"
        alt="{{ section.alt or '' }}"
        sizes="(min-width: 64em) 55rem, 100vw" />
      <img
        class="themed-media themed-media--dark"
        eleventy:widths="600, 900, 1200, 1600"
        eleventy:formats="avif,webp"
        src="/assets/images/{{ section.darkImage }}"
        alt=""
        aria-hidden="true"
        sizes="(min-width: 64em) 55rem, 100vw" />
    {% else %}
      <img
        eleventy:widths="600, 900, 1200, 1600"
        eleventy:formats="avif,webp"
        src="/assets/images/{{ section.image }}"
        alt="{{ section.alt or '' }}"
        sizes="(min-width: 64em) 55rem, 100vw" />
    {% endif %}
  </div>
</section>
